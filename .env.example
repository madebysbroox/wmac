SQUARE_RELAY_BASE_URL=https://YOUR_API_ID.execute-api.YOUR_REGION.amazonaws.com
SQUARE_RELAY_SYNC_TOKEN=replace-with-the-same-long-token-used-during-relay-deploy

# Optional fallback for direct Square API sync:
# SQUARE_ACCESS_TOKEN=
# SQUARE_ENVIRONMENT=production
# SQUARE_LOCATION_ID=

# Optional Worldpay POS transaction staging. Prefer a relay if Worldpay needs a
# cloud/webhook bridge, or point WORLDPAY_TRANSACTIONS_URL at an approved
# transaction export endpoint that returns JSON with payments/transactions.
# WORLDPAY_RELAY_BASE_URL=https://YOUR_WORLDPAY_RELAY.example.com
# WORLDPAY_RELAY_SYNC_TOKEN=replace-with-a-long-local-sync-token
# WORLDPAY_TRANSACTIONS_URL=
# WORLDPAY_ACCESS_TOKEN=
# WORLDPAY_BASIC_AUTH=username:password
